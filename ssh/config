# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config


# DevPod Start connexions.devpod
Host connexions.devpod
  ForwardAgent yes
  LogLevel error
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  HostKeyAlgorithms rsa-sha2-256,rsa-sha2-512,ssh-rsa
  ProxyCommand "/Applications/DevPod.app/Contents/MacOS/devpod-cli" ssh --stdio --context default --user root connexions --workdir "/workspaces/connexions"
  User root
# DevPod End connexions.devpod
# DevPod Start fairplay.devpod
Host fairplay.devpod
  ForwardAgent yes
  LogLevel error
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  HostKeyAlgorithms rsa-sha2-256,rsa-sha2-512,ssh-rsa
  ProxyCommand "/Applications/DevPod.app/Contents/MacOS/devpod-cli" ssh --stdio --context default --user root fairplay --workdir "/workspaces/fairplay"
  User root
# DevPod End fairplay.devpod
Host *
  AddKeysToAgent yes
  IdentitiesOnly yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519

  # Do NOT use ForwardAgent, use ProxyCommand instead
  # https://heipei.github.io/2015/02/26/SSH-Agent-Forwarding-considered-harmful/
  ForwardAgent no
  HashKnownHosts no
  ConnectTimeout 2

#   StrictHostKeyChecking ask
#   ServerAliveCountMax 6
#   ServerAliveInterval 30
#   KeepAlive yes

