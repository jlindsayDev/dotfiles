[credential]
	helper = 
	helper = /usr/local/share/gcm-core/git-credential-manager

[hub]
	protocol = ssh

# Sign Commits

[gpg]
	format = ssh
[commit]
	gpgSign = false
[tag]
	gpgSign = false
	forceSignAnnotated = true

[init]
	defaultBranch = main
[core]
	pager = diff-so-fancy | less --tabs=4 -FRSX
	whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
	editor = nano
	excludesfile = /Users/josh/.config/git/gitignore_global
    sparseCheckoutCone = false
[status]
	short = true
[branch]
	autoSetupMerge = always
	autosetuprebase = always
[push]
	ff = true
	autoSetupRemote = true
[pull]
	ff = true
	rebase = true
[merge]
	ff = true
[log]
	decorate = short
[difftool]
	prompt = false
[interactive]
	diffFilter = diff-so-fancy --patch

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[include]
	path = ~/.config/git/color.gitconfig

[include]
	path = ~/.config/git/alias.gitconfig
[credential "https://dev.azure.com"]
	useHttpPath = true
